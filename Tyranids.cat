      <rules>
        <rule name="Bio-Ammo" id="434f-2fd8-1fea-cb62" hidden="false">
          <description>When creating an Army Roster, a Player selecting a Unit with this Special Rule must also select one of the following options. All Models in the Unit must select the same option.


A Model with the Bio-Ammo Special Rule then 
gains the respective Special Rule for all Shooting Attacks made by that Model and for any Hits generated from the Explodes (X) Special Rule made by that Model. In addition, any Spore Mine Models generated by a Model with the Bio-Ammo Special Rule also have the same selected option as the Model which created the Spore Mine Models. (For example, if Biovore Brood that has selected Toxin  would have to generate a Spore Mine Cluster Unit, those Spore Mine models would also have the Toxin option selected for them</description>
        </rule>
      </rules>
    </selectionEntryGroup>
    <selectionEntryGroup name="Hive Mind Discipline" id="64bf-972a-f8b7-8ad5" hidden="false">
      <selectionEntries>
        <selectionEntry type="upgrade" import="true" name="Catalyst" hidden="false" id="6187-1314-f849-d18d">
          <profiles>
            <profile name="Catalyst" typeId="2419-f21d-c5b6-4c0e" typeName="Psychic Power" hidden="false" id="be1d-9f98-072b-f8fa">
              <characteristics>
                <characteristic name="Summary" typeId="d5d9-2b47-769c-0ab9"/>
                <characteristic name="Phase" typeId="dfad-1a80-d7a3-b97d">Your Movement Phase</characteristic>
                <characteristic name="Target" typeId="223f-5d11-179d-da08">Friendly Tyranid within Synapse Range of this PSYKER</characteristic>
                <characteristic name="Effect" typeId="4d52-090c-e43b-9c4c">Until the start of your next turn, models in that unit gain the Feel No Pain (5+) ability.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <constraints>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="f382-5bec-3355-0bac" includeChildSelections="false"/>
          </constraints>
        </selectionEntry>
        <selectionEntry type="upgrade" import="true" name="The Horror" hidden="false" id="8734-30d4-5d86-bd49">
          <profiles>
            <profile name="The Horror" typeId="2419-f21d-c5b6-4c0e" typeName="Psychic Power" hidden="false" id="ee7f-5ea6-e4c7-0714">
              <characteristics>
                <characteristic name="Summary" typeId="d5d9-2b47-769c-0ab9"/>
                <characteristic name="Phase" typeId="dfad-1a80-d7a3-b97d">Your Movement Phase</characteristic>
