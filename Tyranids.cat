    <selectionEntry type="upgrade" import="true" name="Toxin Sacs" hidden="false" id="0d71-924c-33e3-95ee" sortIndex="84">
      <profiles>
        <profile name="Toxin Sacs" typeId="2c11-4ec5-60b9-9d46" typeName="Wargear" hidden="false" id="bc77-4354-bd0e-a7b6">
          <characteristics>
            <characteristic name="Summary" typeId="fdcc-276a-cadb-7810"/>
            <characteristic name="Description" typeId="516b-bc6f-e52f-aced">A Model with Toxin Sacs and without the Monster Trait gains the Poisoned (4+) Special Rule for all Hits inflicted during the Fight Sub-Phase. A Model with Toxin Sacs and the Monster Trait instead gains the Critical Hit (6+) Special Rule for all Hits inflicted during the Fight Sub-Phase.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <infoLinks>
        <infoLink name="Poisoned (X)" id="37e4-17f2-5c11-5f79" hidden="false" type="rule" targetId="227e-f7c5-2aae-5932">
          <comment>4+</comment>
          <modifiers>
            <modifier type="set" value="Poisoned (4+)" field="name"/>
          </modifiers>
        </infoLink>
        <infoLink name="Critical Hit (X)" id="0776-4086-4d1b-3008" hidden="false" type="rule" targetId="57e4-1ff4-c160-0466">
          <comment>6+</comment>
          <modifiers>
            <modifier type="set" value="Critical Hit (6+" field="name"/>
          </modifiers>
        </infoLink>
      </infoLinks>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Adrenal Glands" hidden="false" id="dc16-bfe8-b3fd-01cb" sortIndex="82">
      <profiles>
        <profile name="Adrenal Glands" typeId="2c11-4ec5-60b9-9d46" typeName="Wargear" hidden="false" id="aaac-ff72-4d2d-375d">
          <characteristics>
            <characteristic name="Summary" typeId="fdcc-276a-cadb-7810"/>
            <characteristic name="Description" typeId="516b-bc6f-e52f-aced">A Model with Adrenal Glands gains the Impact (S and I) Special Rule.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <infoLinks>
        <infoLink name="Impact (X)" id="0cb8-0918-7ba4-bf2e" hidden="false" type="rule" targetId="6499-61b9-e3b6-b748">
          <comment>s</comment>
          <modifiers>
            <modifier type="set" value="Impact (S)" field="name"/>
          </modifiers>
        </infoLink>
      </infoLinks>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Acid Blood" hidden="false" id="38ae-222f-f664-7c53" sortIndex="81">
      <profiles>
        <profile name="Acid Blood" typeId="2c11-4ec5-60b9-9d46" typeName="Wargear" hidden="false" id="22ed-dc1e-f98a-8540">
          <characteristics>
            <characteristic name="Summary" typeId="fdcc-276a-cadb-7810"/>
            <characteristic name="Description" typeId="516b-bc6f-e52f-aced">At the start of the Resolution Sub-Phase the Assault Phase, any enemy Units that were in Combat with a Model with Acid Blood must make a number of Initiative Tests equal to the number of Damage that the Model with Acid Blood suffered. Every failed Test causes the enemy unit to suffer a Wound with an AP of 2 and a Damage Characteristic of 1. No Cover Save or Damage Mitigation Roll may be made to discard this wound, but Invulnerable Saves may still be made. Models removed as a Casualty as a result of this, are counted towards Combat Resolution.</characteristic>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Toxic Miasma" hidden="false" id="1604-aebe-9305-074d" sortIndex="80">
      <profiles>
        <profile name="Toxic Miasma" typeId="2c11-4ec5-60b9-9d46" typeName="Wargear" hidden="false" id="ce07-fe86-8588-91a5">
          <characteristics>
            <characteristic name="Summary" typeId="fdcc-276a-cadb-7810"/>
            <characteristic name="Description" typeId="516b-bc6f-e52f-aced">During the Effects Sub-Phase of the End Phase, every Enemy Unit with Models in Base-to-Base Contact with a Model with Toxic Miasma must make a number of Toughness Tests equal to the amount of Models in Base-To-Base Contact. Every failed Test causes the enemy unit to suffer a wound with an AP of 2, a Damage Characteristic of 1, and the Phage (S) Special Rule. No Cover Save or Damage Mitigation Roll may be made to discard this wound, but Invulnerable Saves may still be made.</characteristic>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Regeneration" hidden="false" id="c93a-853d-5dd1-b908" sortIndex="83">
      <profiles>
        <profile name="Regeneration" typeId="2c11-4ec5-60b9-9d46" typeName="Wargear" hidden="false" id="1730-6999-58b2-1abd">
          <characteristics>
            <characteristic name="Summary" typeId="fdcc-276a-cadb-7810"/>
            <characteristic name="Description" typeId="516b-bc6f-e52f-aced">During the Effects Sub-Phase of the Start Phase, a Model with Regeneration can roll a number of Dice equal to the difference between the Model’s starting Wounds Characteristic and it’s current Wounds Characteristic. For every result of “6”, that Model increases it’s current Wounds Characteristic by one.</characteristic>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Lictor claws and talons" hidden="false" id="a521-0a14-a42a-5916">
      <profiles>
        <profile name="Lictor claws and talons" typeId="ff5e-5aa3-9076-d1ac" typeName="Melee Weapon" hidden="false" id="2710-b636-a815-1a22">
          <characteristics>
            <characteristic name="I" typeId="93cf-082c-7341-87f7">I</characteristic>
            <characteristic name="A" typeId="a356-7e7a-c37d-b824">A</characteristic>
