            <selectionEntryGroup name="Enhancements" id="8655-b574-5b8c-af64" hidden="false">
              <selectionEntries>
                <selectionEntry type="upgrade" import="true" name="Old Adversary" hidden="false" id="b13b-02e2-c610-48e2">
                  <profiles>
                    <profile name="Old Adversary" typeId="2c11-4ec5-60b9-9d46" typeName="Wargear" hidden="false" id="93fd-df40-a8f8-80bd">
                      <characteristics>
                        <characteristic name="Summary" typeId="fdcc-276a-cadb-7810">Hive Tyrants cannot truly die. With every death, the Hive Mind rebuilds the Tyrant with it’s memories and personality maintained and in tact, ready to plague the galaxy once again.</characteristic>
                        <characteristic name="Description" typeId="516b-bc6f-e52f-aced">A Model with Old Adversary gains the Hatred (Command) Special Rule.</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <infoLinks>
                    <infoLink name="Hatred (X)" id="20a6-c0fd-2b99-db3d" hidden="false" type="rule" targetId="6ed1-d5fc-9fea-3edc">
                      <modifiers>
                        <modifier type="set" value="Hatred (Command)" field="name"/>
                      </modifiers>
                      <comment>Command</comment>
                    </infoLink>
                  </infoLinks>
                  <costs>
                    <cost name="Points" typeId="64d7-ccd2-e4b7-b956" value="5"/>
                  </costs>
                </selectionEntry>
                <selectionEntry type="upgrade" import="true" name="Indescribable Horror" hidden="false" id="8fbf-a29f-a3e8-b48b">
                  <profiles>
                    <profile name="Indescribable Horror" typeId="2c11-4ec5-60b9-9d46" typeName="Wargear" hidden="false" id="4f15-cecd-9ec5-46fa">
                      <characteristics>
                        <characteristic name="Summary" typeId="fdcc-276a-cadb-7810">The psychic aura a Hive Tyrant eminates can make even the most veteran of commanders tremble in fear.</characteristic>
                        <characteristic name="Description" typeId="516b-bc6f-e52f-aced">A Model with Indescribable Horror gains the Fear (2) Special Rule.</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <infoLinks>
                    <infoLink name="Fear (X)" id="c118-da40-fa54-833e" hidden="false" type="rule" targetId="0b8e-22b9-4a68-a71e">
                      <modifiers>
                        <modifier type="set" value="Fear (2)" field="name"/>
                      </modifiers>
                      <comment>2</comment>
                    </infoLink>
                  </infoLinks>
                  <costs>
                    <cost name="Points" typeId="64d7-ccd2-e4b7-b956" value="10"/>
                  </costs>
                </selectionEntry>
                <selectionEntry type="upgrade" import="true" name="Hive Commander" hidden="false" id="3817-cf0d-33fa-802e">
                  <profiles>
                    <profile name="Hive Commander" typeId="2c11-4ec5-60b9-9d46" typeName="Wargear" hidden="false" id="6fc0-1b00-cd92-9f7e">
                      <characteristics>
                        <characteristic name="Summary" typeId="fdcc-276a-cadb-7810">The Hive Tyrant is the will of the Hive Mind made manifest, and has a near perfect control over the swarm.</characteristic>
                        <characteristic name="Description" typeId="516b-bc6f-e52f-aced">While a Model with Hive Commander is on the Battlefield, the result of Reserves Tests made by the Controlling Player are modified by +1</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <costs>
                    <cost name="Points" typeId="64d7-ccd2-e4b7-b956" value="10"/>
                  </costs>
                </selectionEntry>
              </selectionEntries>
