    <selectionEntryGroup name="Librarius Discipline" id="74d0-69d5-c119-a0ca" hidden="false">
      <selectionEntries>
        <selectionEntry type="upgrade" import="true" name="Veil of Time" hidden="false" id="6c44-f72e-b812-38d6">
          <profiles>
            <profile name="Veil of Time" typeId="2419-f21d-c5b6-4c0e" typeName="Psychic Power" hidden="false" id="53a5-45f7-c9b8-18c0">
              <characteristics>
                <characteristic name="Summary" typeId="d5d9-2b47-769c-0ab9"/>
                <characteristic name="Phase" typeId="dfad-1a80-d7a3-b97d">Movement Phase</characteristic>
                <characteristic name="Target" typeId="223f-5d11-179d-da08">One friendly Adeptus Astartes unit within 18&quot;</characteristic>
                <characteristic name="Effect" typeId="4d52-090c-e43b-9c4c">Until the end of the turn, you can re-roll charge rolls made for that unit, and add 1 to the Initiative characteristic of models in that unit.</characteristic>
                <characteristic name="Difficulty" typeId="0a8f-2803-6463-22f8"/>
              </characteristics>
            </profile>
          </profiles>
          <constraints>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="2ad4-cee8-aaf8-52f8" includeChildSelections="false"/>
          </constraints>
        </selectionEntry>
        <selectionEntry type="upgrade" import="true" name="Might of Heroes" hidden="false" id="37d8-a893-b375-eaf9">
          <profiles>
            <profile name="Might of Heroes" typeId="2419-f21d-c5b6-4c0e" typeName="Psychic Power" hidden="false" id="d888-3a33-ce31-6b65">
              <characteristics>
                <characteristic name="Summary" typeId="d5d9-2b47-769c-0ab9"/>
                <characteristic name="Phase" typeId="dfad-1a80-d7a3-b97d">Movement Phase</characteristic>
                <characteristic name="Target" typeId="223f-5d11-179d-da08">One friendly Adeptus Astartes Infantry Character model within 12&quot;</characteristic>
                <characteristic name="Effect" typeId="4d52-090c-e43b-9c4c">Until the start of your next turn, that model gains a bonus of +2 to their Strength and Toughness Characteristics</characteristic>
                <characteristic name="Difficulty" typeId="0a8f-2803-6463-22f8"/>
              </characteristics>
