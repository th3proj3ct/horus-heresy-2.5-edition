  <sharedRules>
    <rule name="Psyker (X)" id="316c-f713-737e-c142" hidden="false">
      <description>A Psyker model can manifest and/or make psychic attacks with a number of abilities/weapons as specified by the (X) value in this rule.</description>
    </rule>
