            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="64d2-c282-73ec-7108" includeChildSelections="false"/>
          </constraints>
        </selectionEntry>
        <selectionEntry type="upgrade" import="true" name="Null Zone" hidden="false" id="3a18-f85e-ac0f-11bf">
          <profiles>
            <profile name="Null Zone" typeId="2419-f21d-c5b6-4c0e" typeName="Psychic Power" hidden="false" id="deb4-75f0-0297-36e5">
              <characteristics>
                <characteristic name="Summary" typeId="d5d9-2b47-769c-0ab9"/>
                <characteristic name="Phase" typeId="dfad-1a80-d7a3-b97d">Movement Phase</characteristic>
                <characteristic name="Target" typeId="223f-5d11-179d-da08">Self</characteristic>
                <characteristic name="Effect" typeId="4d52-090c-e43b-9c4c">Until the start of your next turn, while a unit is within 6&quot; of this psyker, invulnerable saving throws cannot be made against that attack</characteristic>
                <characteristic name="Difficulty" typeId="0a8f-2803-6463-22f8">1</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <constraints>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="f307-d2d6-6351-9b30" includeChildSelections="false"/>
          </constraints>
        </selectionEntry>
        <selectionEntry type="upgrade" import="true" name="Psychic Scourge" hidden="false" id="e167-3642-b190-11aa">
          <profiles>
            <profile name="Psychic Scourge" typeId="2419-f21d-c5b6-4c0e" typeName="Psychic Power" hidden="false" id="9ae8-356c-e73c-4318">
              <characteristics>
                <characteristic name="Summary" typeId="d5d9-2b47-769c-0ab9"/>
                <characteristic name="Phase" typeId="dfad-1a80-d7a3-b97d">Shooting Phase</characteristic>
                <characteristic name="Target" typeId="223f-5d11-179d-da08">One enemy unit within 18&quot; and visible to this Psyker</characteristic>
                <characteristic name="Effect" typeId="4d52-090c-e43b-9c4c">Roll a D6 and add it to this model&apos;s Willpower. Your opponent then rolls a D6 and adds it to that unit&apos;s Willpower. If your result is higher than your opponent&apos;s, the selected unit suffers D3+1 S8 AP2 D1 hits.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <constraints>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="20a8-1a6b-9495-41cb" includeChildSelections="false"/>
          </constraints>
        </selectionEntry>
