        <selectionEntry type="upgrade" import="true" name="Psychic Fortress" hidden="false" id="cb88-eaeb-40ee-3a28">
          <profiles>
            <profile name="Psychic Fortress" typeId="915d-f0d9-f8bc-757a" typeName="Psychic Reaction" hidden="false" id="e714-5bb3-4298-7116">
              <characteristics>
                <characteristic name="Summary" typeId="1ce7-2504-85e7-02dc"/>
                <characteristic name="Trigger" typeId="0a94-dd23-6e32-2b1b">This unit is selected as the target of a ranged attack</characteristic>
                <characteristic name="Target" typeId="ca36-7d09-3e09-894b">Self</characteristic>
                <characteristic name="Effect" typeId="e694-20ce-569a-42df">Until the end of the phase, models in this unit gain a 5+ Shrouded Damage Mitigation Test against any wounds inflicted during a Volley or Shooting Attack.</characteristic>
